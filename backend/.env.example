PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
CLIENT_URLS=https://flipkart-gamma-nine.vercel.app,http://localhost:5173

# MySQL Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=flipkart
DB_PORT=3306

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE=24h

# SMTP Email Configuration (Optional - Falls back to console log if blank)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@flipkart-clone.com

# Razorpay QR Payments (Optional - demo QR is shown if blank)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_ALLOW_DEMO_FALLBACK=true
RAZORPAY_FORCE_DEMO_QR=false
